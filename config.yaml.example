display:
  interval_minutes: 60
  no_repeat_days: 7
  orientation: portrait
  strip_text_color: "auto"   # auto | #ffffff (white) | #000000 (black) | any hex color
  sleep_start: ""   # HH:MM — display blanks at this hour (blank to disable)
  sleep_end: ""     # HH:MM — display resumes at this hour
  strip:
    enabled: true
    weather: true
    transit: true
    ip: true
    cpu_temp: true
    aqi: true
    location: true  # GPS reverse-geocode (requires photo EXIF GPS data)

sources:
  local_folder:
    enabled: true
    path: /home/pi/photos
  upload:
    enabled: true
  nextcloud:
    enabled: false
    url: https://your.nextcloud.instance
    username: ""
    password: ""
    remote_path: /Photos/frame
    sync_interval_minutes: 30

  nga:
    enabled: false              # National Gallery of Art open-access collection
    cache_size: 50              # number of artworks to keep on disk

weather:
  enabled: true
  api_key: ""
  city: Munich
  country_code: DE
  units: metric
  refresh_interval_minutes: 30

transit:
  enabled: true
  mvg_global_id: de:09162:1740
  line: S8
  direction_filter: Marienplatz
  limit: 2
  refresh_interval_minutes: 2

web:
  port: 80
  secret_key: ""

telegram:
  bot_token: ""   # from @BotFather — leave blank to disable

pi:
  hostname: epaper-frame
